                State.searchQuery = '';\
                State.filterStatus = 'all';\
                State.filterPayment = 'all';\
                State.filterTeller = 'all';\
                State.filterDate = '';\
                State.currentPageNum = 1;\
                renderQueues();\
            \});\
\
            // Filter key listeners\
            document.getElementById('queue-search').addEventListener('input', (e) => \{\
                State.searchQuery = e.target.value;\
                State.currentPageNum = 1;\
                renderQueues();\
            \});\
            document.getElementById('filter-status').addEventListener('change', (e) => \{\
                State.filterStatus = e.target.value;\
                State.currentPageNum = 1;\
                renderQueues();\
            \});\
            document.getElementById('filter-payment').addEventListener('change', (e) => \{\
                State.filterPayment = e.target.value;\
                State.currentPageNum = 1;\
                renderQueues();\
            \});\
            document.getElementById('filter-teller').addEventListener('change', (e) => \{\
                State.filterTeller = e.target.value;\
                State.currentPageNum = 1;\
                renderQueues();\
            \});\
            document.getElementById('filter-date').addEventListener('change', (e) => \{\
                State.filterDate = e.target.value;\
                State.currentPageNum = 1;\
                renderQueues();\
            \});\
\
            // Pagination button listeners\
            document.getElementById('pagination-prev-btn').addEventListener('click', () => \{\
                if (State.currentPageNum > 1) \{\
                    State.currentPageNum--;\
                    renderQueues();\
                \}\
            \});\
            document.getElementById('pagination-next-btn').addEventListener('click', () => \{\
                const filteredCount = State.queues.length; // Approximate\
                const totalPages = Math.ceil(filteredCount / State.itemsPerPage);\
                if (State.currentPageNum < totalPages) \{\
                    State.currentPageNum++;\
                    renderQueues();\
                \}\
            \});\
\
            document.getElementById('view-all-queues-shortcut').addEventListener('click', () => \{\
                navigateToPage('queues');\
            \});\
\
            // Teller form submit listener\
            document.getElementById('teller-form').addEventListener('submit', (e) => \{\
                e.preventDefault();\
                const id = document.getElementById('teller-form-id').value;\
                const name = document.getElementById('teller-name').value.trim();\
                const pageName = document.getElementById('teller-page-name').value.trim();\
                const tel = document.getElementById('teller-tel').value.trim();\
                const contact = document.getElementById('teller-contact').value.trim();\
                const status = document.getElementById('teller-status').value;\
                const avatar = document.getElementById('teller-avatar-input').value;\
\
                // Simple validation\
                let hasError = false;\
                if (!name) \{\
                    document.getElementById('teller-name-error').innerText = '\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3585 \u3619 \u3629 \u3585 \u3594 \u3639 \u3656 \u3629 \u3648 \u3621 \u3656 \u3609 \u3649 \u3617 \u3656 \u3627 \u3617 \u3629 ';\
                    document.getElementById('teller-name-error').classList.remove('hidden');\
                    hasError = true;\
                \} else \{\
                    document.getElementById('teller-name-error').classList.add('hidden');\
                \}\
\
                if (!pageName) \{\
                    document.getElementById('teller-page-error').innerText = '\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3585 \u3619 \u3629 \u3585 \u3594 \u3639 \u3656 \u3629 \u3627 \u3609 \u3657 \u3634 \u3648 \u3614 \u3592 ';\
                    document.getElementById('teller-page-error').classList.remove('hidden');\
                    hasError = true;\
                \} else \{\
                    document.getElementById('teller-page-error').classList.add('hidden');\
                \}\
\
                if (!tel) \{\
                    document.getElementById('teller-tel-error').innerText = '\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3585 \u3619 \u3629 \u3585 \u3648 \u3610 \u3629 \u3619 \u3660 \u3650 \u3607 \u3619 \u3624 \u3633 \u3614 \u3607 \u3660 ';\
                    document.getElementById('teller-tel-error').classList.remove('hidden');\
                    hasError = true;\
                \} else \{\
                    document.getElementById('teller-tel-error').classList.add('hidden');\
                \}\
\
                if (hasError) return;\
\
                const formData = \{ name, pageName, tel, contact, status, avatar \};\
\
                if (id) \{\
                    // Update existing\
                    State.tellers = State.tellers.map(t => t.id === id ? \{ ...t, ...formData \} : t);\
                    showToast('\uc0\u9989  \u3649 \u3585 \u3657 \u3652 \u3586 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592 ');\
                \} else \{\
                    // Create new\
                    const newId = 't_' + Date.now();\
                    State.tellers.push(\{ id: newId, ...formData \});\
                    showToast('\uc0\u9989  \u3610 \u3633 \u3609 \u3607 \u3638 \u3585 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592 ');\
                \}\
\
                saveStateToStorage();\
                document.getElementById('teller-modal').classList.add('hidden');\
                renderTellers();\
                populateFormSelectors();\
            \});\
\
            // Package form submit listener\
            document.getElementById('package-form').addEventListener('submit', (e) => \{\
                e.preventDefault();\
                const id = document.getElementById('package-form-id').value;\
                const name = document.getElementById('package-name').value.trim();\
                const type = document.getElementById('package-type').value;\
                const price = parseFloat(document.getElementById('package-price').value);\
                const detail = document.getElementById('package-detail').value.trim();\
\
                let hasError = false;\
                if (!name) \{\
                    document.getElementById('package-name-error').innerText = '\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3585 \u3619 \u3629 \u3585 \u3594 \u3639 \u3656 \u3629 \u3649 \u3614 \u3655 \u3585 \u3648 \u3585 \u3592 ';\
                    document.getElementById('package-name-error').classList.remove('hidden');\
                    hasError = true;\
                \} else \{\
                    document.getElementById('package-name-error').classList.add('hidden');\
                \}\
\
                if (isNaN(price) || price < 0) \{\
                    document.getElementById('package-price-error').innerText = '\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3585 \u3619 \u3629 \u3585 \u3619 \u3634 \u3588 \u3634 \u3651 \u3627 \u3657 \u3606 \u3641 \u3585 \u3605 \u3657 \u3629 \u3591 ';\
                    document.getElementById('package-price-error').classList.remove('hidden');\
                    hasError = true;\
                \} else \{\
                    document.getElementById('package-price-error').classList.add('hidden');\
                \}\
\
                if (hasError) return;\
\
                const formData = \{ name, type, price, detail \};\
\
                if (id) \{\
                    State.packages = State.packages.map(p => p.id === id ? \{ ...p, ...formData \} : p);\
                    showToast('\uc0\u9989  \u3649 \u3585 \u3657 \u3652 \u3586 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592 ');\
                \} else \{\
                    const newId = 'p_' + Date.now();\
                    State.packages.push(\{ id: newId, ...formData \});\
                    showToast('\uc0\u9989  \u3610 \u3633 \u3609 \u3607 \u3638 \u3585 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592 ');\
                \}\
\
                saveStateToStorage();\
                document.getElementById('package-modal').classList.add('hidden');\
                renderPackages();\
                populateFormSelectors();\
            \});\
\
            // Queue form submit listener\
            document.getElementById('queue-form').addEventListener('submit', (e) => \{\
                e.preventDefault();\
                const id = document.getElementById('queue-form-id').value;\
                let queueCode = document.getElementById('queue-form-code').value;\
                const nickname = document.getElementById('queue-nickname').value.trim();\
                const fullname = document.getElementById('queue-fullname').value.trim();\
                const age = parseInt(document.getElementById('queue-age').value) || '';\
                const gender = document.getElementById('queue-gender').value;\
                const contactChannel = document.getElementById('queue-contact-channel').value;\
                const contactAccount = document.getElementById('queue-contact-account').value.trim();\
                const profileLink = document.getElementById('queue-profile-link').value.trim();\
                const tellerId = document.getElementById('queue-teller-id').value;\
                const packageId = document.getElementById('queue-package-id').value;\
                const questionCount = parseInt(document.getElementById('queue-question-count').value) || 1;\
                const totalPrice = parseFloat(document.getElementById('queue-total-price').value) || 0;\
                const paymentStatus = document.getElementById('queue-payment-status').value;\
                const paidAmount = parseFloat(document.getElementById('queue-paid-amount').value) || 0;\
                const estDate = document.getElementById('queue-est-date').value;\
                const estTime = document.getElementById('queue-est-time').value;\
                const jobStatus = document.getElementById('queue-job-status').value;\
                const questions = document.getElementById('queue-questions').value.trim();\
                const notes = document.getElementById('queue-notes').value.trim();\
\
                let hasError = false;\
                if (!nickname) \{\
                    document.getElementById('queue-nickname-error').innerText = '\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3585 \u3619 \u3629 \u3585 \u3594 \u3639 \u3656 \u3629 \u3648 \u3621 \u3656 \u3609 \u3621 \u3641 \u3585 \u3604 \u3623 \u3591 ';\
                    document.getElementById('queue-nickname-error').classList.remove('hidden');\
                    hasError = true;\
                \} else \{\
                    document.getElementById('queue-nickname-error').classList.add('hidden');\
                \}\
\
                if (!contactAccount) \{\
                    document.getElementById('queue-contact-account-error').innerText = '\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3585 \u3619 \u3629 \u3585 \u3610 \u3633 \u3597 \u3594 \u3637 \u3605 \u3636 \u3604 \u3605 \u3656 \u3629 \u3627 \u3619 \u3639 \u3629  Username';\
                    document.getElementById('queue-contact-account-error').classList.remove('hidden');\
                    hasError = true;\
                \} else \{\
                    document.getElementById('queue-contact-account-error').classList.add('hidden');\
                \}\
\
                if (!questions) \{\
                    document.getElementById('queue-questions-error').innerText = '\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3585 \u3619 \u3629 \u3585 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3607 \u3637 \u3656 \u3592 \u3632 \u3606 \u3634 \u3617 \u3586 \u3629 \u3591 \u3621 \u3641 \u3585 \u3604 \u3623 \u3591 ';\
                    document.getElementById('queue-questions-error').classList.remove('hidden');\
                    hasError = true;\
                \} else \{\
                    document.getElementById('queue-questions-error').classList.add('hidden');\
                \}\
\
                // Error validation block checks if database records are zero\
                if (State.tellers.length === 0) \{\
                    showToast('\uc0\u9888 \u65039  \u3585 \u3619 \u3640 \u3603 \u3634 \u3648 \u3614 \u3636 \u3656 \u3617 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3649 \u3617 \u3656 \u3627 \u3617 \u3629 \u3648 \u3586 \u3657 \u3634 \u3626 \u3641 \u3656 \u3619 \u3632 \u3610 \u3610 \u3585 \u3656 \u3629 \u3609 \u3610 \u3633 \u3609 \u3607 \u3638 \u3585 \u3588 \u3636 \u3623 ', 'error');\
                    hasError = true;\
                \}\
                if (State.packages.length === 0) \{\
                    showToast('\uc0\u9888 \u65039  \u3585 \u3619 \u3640 \u3603 \u3634 \u3648 \u3614 \u3636 \u3656 \u3617 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3649 \u3614 \u3655 \u3585 \u3648 \u3585 \u3592 \u3619 \u3634 \u3588 \u3634 \u3585 \u3656 \u3629 \u3609 \u3610 \u3633 \u3609 \u3607 \u3638 \u3585 \u3588 \u3636 \u3623 ', 'error');\
                    hasError = true;\
                \}\
\
                if (hasError) return;\
\
                // Auto queue numbering NT-XXXXXX logic\
                if (!id) \{\
                    const lastNum = State.queues.reduce((max, q) => \{\
                        const num = parseInt(q.queueCode.replace('NT-', ''), 10);\
                        return num > max ? num : max;\
                    \}, 0);\
                    const nextNum = lastNum + 1;\
                    queueCode = `NT-$\{String(nextNum).padStart(6, '0')\}`;\
                \}\
\
                const formData = \{\
                    queueCode, nickname, fullname, age, gender, contactChannel, contactAccount, profileLink,\
                    tellerId, packageId, questionCount, totalPrice, paymentStatus, paidAmount, estDate, estTime,\
                    jobStatus, questions, notes,\
                    createdAt: id ? (State.queues.find(item => item.id === id).createdAt) : new Date().toISOString()\
                \};\
\
                if (id) \{\
                    State.queues = State.queues.map(q => q.id === id ? \{ ...q, ...formData \} : q);\
                    showToast('\uc0\u9989  \u3649 \u3585 \u3657 \u3652 \u3586 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592 ');\
                \} else \{\
                    const newId = 'q_' + Date.now();\
                    State.queues.unshift(\{ id: newId, ...formData \});\
                    showToast('\uc0\u9989  \u3610 \u3633 \u3609 \u3607 \u3638 \u3585 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592 ');\
                    localStorage.removeItem('tarot_draft_queue');\
                    document.getElementById('dash-restore-draft-btn').classList.add('hidden');\
                \}\
\
                saveStateToStorage();\
                document.getElementById('queue-modal').classList.add('hidden');\
                navigateToPage(State.currentPage);\
            \});\
        \});\
\
        // Open clean blank queue form\
        function openNewQueueModal() \{\
            document.getElementById('queue-modal-title').innerText = '\uc0\u55358 \u56793 \u8205 \u9792 \u65039  \u3648 \u3614 \u3636 \u3656 \u3617 \u3611 \u3619 \u3632 \u3623 \u3633 \u3605 \u3636 \u3588 \u3636 \u3623 \u3592 \u3629 \u3591 \u3604 \u3641 \u3604 \u3623 \u3591 \u3586 \u3629 \u3591 \u3621 \u3641 \u3585 \u3604 \u3623 \u3591 ';\
            document.getElementById('queue-form-id').value = '';\
            document.getElementById('queue-form-code').value = '';\
            document.getElementById('queue-form').reset();\
            \
            // Default Date ETA: tomorrow\
            const tomorrow = new Date();\
            tomorrow.setDate(tomorrow.getDate() + 1);\
            document.getElementById('queue-est-date').value = tomorrow.toISOString().split('T')[0];\
            document.getElementById('queue-est-time').value = '20:00';\
            \
            // Set default selectors\
            if (State.tellers.length > 0) document.getElementById('queue-teller-id').value = State.tellers[0].id;\
            if (State.packages.length > 0) document.getElementById('queue-package-id').value = State.packages[0].id;\
\
            calculateQueueAmounts();\
            document.getElementById('queue-modal').classList.remove('hidden');\
        \}\
    </script>\
