        // Analytics Page Render Function\
        function renderAnalytics() \{\
            const stats = getAnalyticsStats();\
\
            // Total statistics values\
            document.getElementById('stats-total-customers').innerText = stats.newCustomersCount + stats.returningCustomersCount;\
            document.getElementById('stats-new-customers').innerText = `$\{stats.newCustomersCount\} \uc0\u3588 \u3609 `;\
            document.getElementById('stats-returning-customers').innerText = `$\{stats.returningCustomersCount\} \uc0\u3588 \u3609 `;\
\
            // Draw SVG Revenue Chart dynamically\
            const svgContainer = document.getElementById('analytics-chart-svg-container');\
            const maxVal = Math.max(...stats.revenueByDay.map(d => d.amount), 500);\
\
            svgContainer.innerHTML = stats.revenueByDay.map((day, idx) => \{\
                const barHeight = maxVal > 0 ? (day.amount / maxVal) * 100 : 0;\
                return `\
                    <div class="flex-1 flex flex-col items-center gap-2 group cursor-pointer h-full justify-end">\
                        <div class="text-[10px] font-bold text-purple-600 dark:text-purple-400 opacity-0 group-hover:opacity-100 transition-opacity">\
                            $\{day.amount\} \uc0\u3610 .\
                        </div>\
                        \
                        <!-- Bar -->\
                        <div style="height: $\{Math.max(barHeight, 8)\}%" class="w-full rounded-t-xl bg-gradient-to-t from-purple-500 to-indigo-500 hover:from-purple-600 hover:to-indigo-600 transition-all shadow-md shadow-purple-500/10"></div>\
                        \
                        <!-- Label -->\
                        <div class="text-[10px] font-semibold text-zinc-400 mt-1">\
                            $\{day.label\}\
                        </div>\
                    </div>\
                `;\
            \}).join('');\
\
            // Render Social Channels stats lists\
            const channelsContainer = document.getElementById('stats-channels-container');\
            const totalQueuesCount = State.queues.length || 1;\
\
            const channelsData = [\
                \{ channel: 'LINE', count: State.queues.filter(q => q.contactChannel === 'LINE').length, color: 'bg-emerald-500' \},\
                \{ channel: 'Facebook', count: State.queues.filter(q => q.contactChannel === 'Facebook').length, color: 'bg-blue-600' \},\
                \{ channel: 'Instagram', count: State.queues.filter(q => q.contactChannel === 'Instagram').length, color: 'bg-pink-500' \},\
                \{ channel: 'TikTok', count: State.queues.filter(q => q.contactChannel === 'TikTok').length, color: 'bg-zinc-900 dark:bg-white' \},\
                \{ channel: '\uc0\u3629 \u3639 \u3656 \u3609  \u3654 ', count: State.queues.filter(q => !['LINE','Facebook','Instagram','TikTok'].includes(q.contactChannel)).length, color: 'bg-purple-400' \},\
            ].sort((a, b) => b.count - a.count);\
\
            channelsContainer.innerHTML = channelsData.map(item => \{\
                const percentage = Math.round((item.count / totalQueuesCount) * 100);\
                return `\
                    <div class="space-y-1">\
                        <div class="flex justify-between text-xs">\
                            <span class="font-semibold dark:text-zinc-300">$\{item.channel\}</span>\
                            <span class="text-zinc-400 dark:text-zinc-500">$\{item.count\} \uc0\u3588 \u3636 \u3623  ($\{percentage\}%)</span>\
                        </div>\
                        <div class="w-full h-1.5 rounded-full bg-zinc-100 dark:bg-zinc-800 overflow-hidden">\
                            <div style="width: $\{percentage\}%" class="h-full $\{item.color\}"></div>\
                        </div>\
                    </div>\
                `;\
            \}).join('');\
        \}\
\
        // Global Page Navigator helper\
        function navigateToPage(pageId) \{\
            State.currentPage = pageId;\
            \
            // Hide all pages\
            document.querySelectorAll('.page-container').forEach(page => \{\
                page.classList.add('hidden');\
            \});\
\
            // Show target page\
            document.getElementById(`$\{pageId\}-page`).classList.remove('hidden');\
\
            // Deactivate all navigation tabs\
            document.querySelectorAll('.nav-tab-btn').forEach(btn => \{\
                btn.classList.remove('border-purple-600', 'text-purple-600', 'dark:text-purple-400');\
                btn.classList.add('border-transparent', 'text-zinc-400');\
            \});\
\
            // Activate target tab button\
            const activeBtn = document.querySelector(`.nav-tab-btn[data-tab="$\{pageId\}"]`);\
            if (activeBtn) \{\
                activeBtn.classList.add('border-purple-600', 'text-purple-600', 'dark:text-purple-400');\
                activeBtn.classList.remove('border-transparent', 'text-zinc-400');\
            \}\
\
            // Breadcrumb UI update\
            const breadcrumbMap = \{\
                dashboard: '\uc0\u3616 \u3634 \u3614 \u3619 \u3623 \u3617  / Dashboard',\
                queues: '\uc0\u3619 \u3632 \u3610 \u3610 \u3592 \u3633 \u3604 \u3585 \u3634 \u3619 \u3588 \u3636 \u3623 \u3621 \u3641 \u3585 \u3604 \u3623 \u3591 ',\
                tellers: '\uc0\u3619 \u3634 \u3618 \u3594 \u3639 \u3656 \u3629 \u3649 \u3617 \u3656 \u3627 \u3617 \u3629 \u3614 \u3618 \u3634 \u3585 \u3619 \u3603 \u3660 ',\
                packages: '\uc0\u3629 \u3633 \u3605 \u3619 \u3634 \u3588 \u3656 \u3634 \u3610 \u3619 \u3636 \u3585 \u3634 \u3619 \u3649 \u3621 \u3632 \u3649 \u3614 \u3655 \u3585 \u3648 \u3585 \u3592 ',\
                analytics: '\uc0\u3619 \u3634 \u3618 \u3591 \u3634 \u3609 \u3649 \u3621 \u3632 \u3585 \u3634 \u3619 \u3623 \u3636 \u3648 \u3588 \u3619 \u3634 \u3632 \u3627 \u3660 \u3648 \u3594 \u3636 \u3591 \u3621 \u3638 \u3585 '\
