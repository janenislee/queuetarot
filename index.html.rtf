        // Queues Page Render Function\
        function renderQueues() \{\
            // Apply Search and Filters\
            const filtered = State.queues.filter(q => \{\
                // Filter by role/selected teller\
                if (State.currentRole === 'FortuneTeller' && State.currentTellerUser) \{\
                    if (q.tellerId !== State.currentTellerUser.id) return false;\
                \} else if (State.currentRole === 'Admin' && State.selectedTellerId !== 'all') \{\
                    if (q.tellerId !== State.selectedTellerId) return false;\
                \}\
\
                // Filter by text search\
                if (State.searchQuery.trim() !== '') \{\
                    const search = State.searchQuery.toLowerCase();\
                    const nickname = (q.nickname || '').toLowerCase();\
                    const fullname = (q.fullname || '').toLowerCase();\
                    const queueCode = (q.queueCode || '').toLowerCase();\
                    const contactAccount = (q.contactAccount || '').toLowerCase();\
                    const isMatch = nickname.includes(search) || \
                                    fullname.includes(search) || \
                                    queueCode.includes(search) || \
                                    contactAccount.includes(search);\
                    if (!isMatch) return false;\
                \}\
\
                // Status Filter\
                if (State.filterStatus !== 'all' && q.jobStatus !== State.filterStatus) return false;\
\
                // Payment Filter\
                if (State.filterPayment !== 'all' && q.paymentStatus !== State.filterPayment) return false;\
\
                // Teller Filter\
                if (State.filterTeller !== 'all' && q.tellerId !== State.filterTeller) return false;\
\
                // Date Filter\
                if (State.filterDate && q.estDate !== State.filterDate) return false;\
\
                return true;\
            \});\
