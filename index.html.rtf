        // Build active warnings & alerts\
        function getSystemAlerts() \{\
            const alerts = [];\
            const now = new Date();\
\
            State.queues.forEach(q => \{\
                if (q.paymentStatus === '\uc0\u3618 \u3633 \u3591 \u3652 \u3617 \u3656 \u3594 \u3635 \u3619 \u3632 ' || q.jobStatus === '\u3619 \u3629 \u3594 \u3635 \u3619 \u3632 \u3648 \u3591 \u3636 \u3609 ') \{\
                    alerts.push(\{\
                        type: 'warning',\
                        title: '\uc0\u3588 \u3657 \u3634 \u3591 \u3594 \u3635 \u3619 \u3632 \u3648 \u3591 \u3636 \u3609 ',\
                        message: `\uc0\u3588 \u3636 \u3623  $\{q.queueCode\} ($\{q.nickname\}) \u3618 \u3633 \u3591 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3594 \u3635 \u3619 \u3632 \u3588 \u3656 \u3634 \u3610 \u3619 \u3636 \u3585 \u3634 \u3619 `,\
                        queueId: q.id\
                    \});\
                \}\
\
                if (q.estDate && q.jobStatus !== '\uc0\u3626 \u3656 \u3591 \u3588 \u3635 \u3607 \u3635 \u3609 \u3634 \u3618 \u3649 \u3621 \u3657 \u3623 ' && q.jobStatus !== '\u3618 \u3585 \u3648 \u3621 \u3636 \u3585 ') \{\
                    try \{\
                        const estTimeStr = q.estTime || '23:59';\
                        const estDateTime = new Date(`$\{q.estDate\}T$\{estTimeStr\}:00`);\
                        const diffMs = estDateTime - now;\
                        const diffHrs = diffMs / (1000 * 60 * 60);\
\
                        if (diffHrs > 0 && diffHrs <= 24) \{\
                            alerts.push(\{\
                                type: 'urgent',\
                                title: '\uc0\u3651 \u3585 \u3621 \u3657 \u3585 \u3635 \u3627 \u3609 \u3604 \u3626 \u3656 \u3591 ',\
                                message: `\uc0\u3588 \u3636 \u3623  $\{q.queueCode\} ($\{q.nickname\}) \u3592 \u3632 \u3588 \u3619 \u3610 \u3585 \u3635 \u3627 \u3609 \u3604 \u3651 \u3609  $\{Math.round(diffHrs)\} \u3594 \u3633 \u3656 \u3623 \u3650 \u3617 \u3591 `,\
                                queueId: q.id\
                            \});\
                        \} else if (diffHrs <= 0) \{\
                            alerts.push(\{\
                                type: 'danger',\
                                title: '\uc0\u3648 \u3621 \u3618 \u3585 \u3635 \u3627 \u3609 \u3604 \u3626 \u3656 \u3591  \u9888 \u65039 ',\
                                message: `\uc0\u3588 \u3636 \u3623  $\{q.queueCode\} ($\{q.nickname\}) \u3648 \u3621 \u3618 \u3585 \u3635 \u3627 \u3609 \u3604 \u3648 \u3623 \u3621 \u3634 \u3626 \u3656 \u3591 \u3649 \u3621 \u3657 \u3623 !`,\
                                queueId: q.id\
                            \});\
                        \}\
                    \} catch (e) \{\}\
                \}\
            \});\
\
            return alerts.slice(0, 6);\
        \}\
