        // Live auto-calculation in Queue Modal\
        function calculateQueueAmounts() \{\
            const pkgId = document.getElementById('queue-package-id').value;\
            const qty = parseInt(document.getElementById('queue-question-count').value) || 1;\
            const pkg = State.packages.find(p => p.id === pkgId);\
            \
            if (pkg) \{\
                const totalPrice = pkg.price * qty;\
                document.getElementById('queue-total-price').value = totalPrice;\
                \
                const payStatus = document.getElementById('queue-payment-status').value;\
                let paidAmountInput = document.getElementById('queue-paid-amount');\
                \
                if (payStatus === '\uc0\u3594 \u3635 \u3619 \u3632 \u3588 \u3619 \u3610 \u3649 \u3621 \u3657 \u3623 ') \{\
                    paidAmountInput.value = totalPrice;\
                \} else if (payStatus === '\uc0\u3618 \u3633 \u3591 \u3652 \u3617 \u3656 \u3594 \u3635 \u3619 \u3632 ') \{\
                    paidAmountInput.value = 0;\
                \}\
\
                const paidAmount = parseFloat(paidAmountInput.value) || 0;\
                document.getElementById('queue-remaining-balance').innerText = totalPrice - paidAmount;\
            \}\
        \}\
